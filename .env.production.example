# Copy to .env for docker compose production

JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
AADHAAR_SALT=change-this-aadhaar-salt-in-production

# Public URL of your deployed frontend (for CORS)
CLIENT_URL=http://localhost

# Optional — Sepolia blockchain (leave empty for mock hashes)
SEPOLIA_RPC_URL=
PRIVATE_KEY=
CONTRACT_ADDRESS=

# Optional — Pinata IPFS (leave empty for mock IPFS hashes)
PINATA_API_KEY=
PINATA_SECRET_KEY=
