# Copy to .env for Docker production

NODE_ENV=production
ENABLE_DEMO_MODE=false

JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d
AADHAAR_SALT=change-this-aadhaar-salt-in-production

CLIENT_URL=http://localhost

# MongoDB (Docker Compose uses mongodb service)
MONGODB_URI=mongodb://mongodb:27017/bhumi

# === YOUR REAL LOGIN (all 10,000 properties assigned to you) ===
REGISTRY_PRIMARY_EMAIL=your.email@gmail.com
REGISTRY_PRIMARY_PASSWORD=YourSecurePass@123
REGISTRY_PRIMARY_FULL_NAME=Your Full Name
REGISTRY_PRIMARY_PHONE=9876543210
REGISTRY_PRIMARY_AADHAAR=789012345674

# Government verifier accounts (created on import)
GOV_EMAIL=gov.official@landregistry.bhumi
GOV_IMPORT_PASSWORD=BhumiGov@2026
VERIFIER_EMAIL=verifier@landregistry.bhumi

# Dataset path inside container
DATASET_XLSX_PATH=/app/data/land_registry_dataset_10000.xlsx
RUN_IMPORT=true

# Optional — Sepolia blockchain
SEPOLIA_RPC_URL=
PRIVATE_KEY=
CONTRACT_ADDRESS=

# Optional — Pinata IPFS
PINATA_API_KEY=
PINATA_SECRET_KEY=
